using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace FloydTriangle
{
    class Program
    {
        static void Main(string[] args)
        {
            int n, num = 1;
            Console.Write("Enter a number of rows:");
            n = Convert.ToInt32(Console.ReadLine());

            Console.WriteLine("\nFloyd's Triangle:\n");

            for(int i = 1; i <= n; i++)
            {
                for(int j = 1; j <= i; j++)
                {
                    Console.Write(num + " ");
                    num++;
                }
                Console.WriteLine();
            }
            Console.ReadKey();
        }
    }
}
